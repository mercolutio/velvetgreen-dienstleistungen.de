{
  "name": "Velvetgreen – Landing Page Notifier (Stündliches Polling)",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "hours",
              "hoursInterval": 1
            }
          ]
        }
      },
      "id": "a1b2c3d4-0001-0001-0001-000000000001",
      "name": "Jede Stunde",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [240, 300]
    },
    {
      "parameters": {
        "url": "https://velvetgreen-dienstleistungen.de/pending-notifications.json",
        "options": {
          "response": {
            "response": {
              "responseFormat": "json"
            }
          }
        }
      },
      "id": "a1b2c3d4-0002-0002-0002-000000000002",
      "name": "Benachrichtigungen abrufen",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [460, 300]
    },
    {
      "parameters": {
        "jsCode": "// Bereits gesendete IDs aus Static Data laden\nconst stored = $getWorkflowStaticData('global');\nconst sentIds = stored.sentIds || [];\n\n// Alle Einträge aus der JSON-Datei\nconst notifications = $input.first().json;\n\n// Nur noch nicht gesendete herausfiltern\nconst pending = Array.isArray(notifications)\n  ? notifications.filter(n => !sentIds.includes(n.id))\n  : [];\n\nif (pending.length === 0) {\n  return [{ json: { hasPending: false } }];\n}\n\n// IDs als gesendet markieren\nstored.sentIds = [...sentIds, ...pending.map(n => n.id)];\n\n// Jeden Eintrag als eigenes Item ausgeben\nreturn pending.map(n => ({ json: { hasPending: true, ...n } }));"
      },
      "id": "a1b2c3d4-0003-0003-0003-000000000003",
      "name": "Ungesendete filtern",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [680, 300]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "cond-has-pending",
              "leftValue": "={{ $json.hasPending }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "true"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "a1b2c3d4-0004-0004-0004-000000000004",
      "name": "Ungesendet?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [900, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://n8n.mercolutio.eu/webhook/velvetgreen-landing-page",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ subject: $json.subject, html_body: $json.html_body }) }}"
      },
      "id": "a1b2c3d4-0005-0005-0005-000000000005",
      "name": "Webhook senden",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1120, 200]
    }
  ],
  "connections": {
    "Jede Stunde": {
      "main": [
        [
          {
            "node": "Benachrichtigungen abrufen",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Benachrichtigungen abrufen": {
      "main": [
        [
          {
            "node": "Ungesendete filtern",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Ungesendete filtern": {
      "main": [
        [
          {
            "node": "Ungesendet?",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Ungesendet?": {
      "main": [
        [
          {
            "node": "Webhook senden",
            "type": "main",
            "index": 0
          }
        ],
        []
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  },
  "staticData": null,
  "tags": [],
  "triggerCount": 0
}
